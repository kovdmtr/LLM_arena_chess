<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ white.display_name }} vs {{ black.display_name }} — {{ event }}</title>
  <style>
    :root { color-scheme: light dark; }
    * { box-sizing: border-box; }
    body {
      font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      margin: 0; padding: 2rem; line-height: 1.5;
      background: #f5f5f4; color: #1c1917;
    }
    main { max-width: 980px; margin: 0 auto; }
    header.report { text-align: center; margin-bottom: 2rem; }
    header.report h1 { margin: 0 0 .25rem; font-size: 1.5rem; }
    header.report .meta { color: #57534e; font-size: .9rem; }
    .players { display: flex; gap: 1rem; justify-content: center; margin: 1rem 0; flex-wrap: wrap; }
    .player { background: #fff; border: 1px solid #e7e5e4; border-radius: .5rem; padding: .75rem 1.25rem; min-width: 200px; }
    .player .side { font-weight: 700; text-transform: uppercase; font-size: .7rem; letter-spacing: .05em; color: #78716c; }
    .player .name { font-size: 1.1rem; font-weight: 600; }
    .player .model { color: #57534e; font-size: .85rem; }
    .result { text-align: center; font-size: 1.25rem; font-weight: 700; margin: 1rem 0; }
    .result .termination { display: block; font-size: .85rem; font-weight: 400; color: #57534e; }
    section.analysis { margin: 0 0 2rem; }
    section.analysis h2 { text-align: center; font-size: 1.1rem; margin: 0 0 1rem; }
    .analysis-sides { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .analysis-side {
      background: #fff; border: 1px solid #e7e5e4; border-radius: .5rem;
      padding: .75rem 1.25rem; min-width: 200px;
    }
    .analysis-side .side-name { font-weight: 600; margin-bottom: .35rem; }
    .analysis-side .accuracy { font-size: 1.4rem; font-weight: 700; }
    .analysis-side .accuracy .label { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: #78716c; }
    .analysis-side .counts { color: #57534e; font-size: .85rem; margin-top: .25rem; }
    ul.key-moments { list-style: none; padding: 0; margin: 1rem auto 0; max-width: 520px; display: grid; gap: .35rem; }
    ul.key-moments li {
      background: #fff; border: 1px solid #e7e5e4; border-radius: .5rem;
      padding: .4rem .75rem; font-size: .9rem;
    }
    ul.key-moments .comment { color: #57534e; }
    ol.moves { list-style: none; padding: 0; margin: 0; display: grid; gap: 1.25rem; }
    li.move {
      background: #fff; border: 1px solid #e7e5e4; border-radius: .5rem;
      padding: 1rem; display: grid; grid-template-columns: auto 1fr; gap: 1rem;
    }
    li.move.no-board { grid-template-columns: 1fr; }
    .board { width: {{ board_size }}px; max-width: 100%; }
    .board svg { width: 100%; height: auto; display: block; }
    .move-body .headline { font-weight: 600; }
    .move-body .num { color: #78716c; }
    .badge {
      display: inline-block; font-size: .7rem; font-weight: 700; padding: .1rem .4rem;
      border-radius: .25rem; background: #e7e5e4; color: #44403c; margin-left: .4rem;
      text-transform: uppercase; letter-spacing: .03em;
    }
    .badge.brilliant { background: #cffafe; color: #155e75; }
    .badge.good { background: #dcfce7; color: #166534; }
    .badge.book { background: #ede9fe; color: #5b21b6; }
    .badge.inaccuracy { background: #fef9c3; color: #854d0e; }
    .badge.mistake { background: #ffedd5; color: #9a3412; }
    .badge.blunder { background: #fee2e2; color: #991b1b; }
    .glyph { font-weight: 700; margin-left: .25rem; color: #44403c; font-variant-ligatures: none; }
    .reasoning { margin: .5rem 0 0; color: #292524; white-space: pre-wrap; }
    .reasoning.empty { color: #a8a29e; font-style: italic; }
    .plan { margin: .5rem 0 0; color: #292524; font-size: .9rem; white-space: pre-wrap; }
    .plan .label { color: #78716c; font-weight: 600; }
    .plan-status { display: inline-block; font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .03em; padding: .1rem .4rem; border-radius: .25rem; margin-right: .4rem; background: #e7e5e4; color: #44403c; }
    .plan-status.status-start { background: #e0f2fe; color: #075985; }
    .plan-status.status-continue { background: #dcfce7; color: #166534; }
    .plan-status.status-adapt { background: #fef9c3; color: #854d0e; }
    .plan-status.status-abandon { background: #fee2e2; color: #991b1b; }
    .hint { margin-top: .5rem; font-size: .85rem; color: #0369a1; }
    .eval { color: #57534e; font-size: .85rem; }
    /* --- интерактивный плеер: одна доска + перемотка ходов --- */
    .replay-stage { display: flex; gap: 1.25rem; align-items: flex-start; flex-wrap: wrap; justify-content: center; }
    .replay-boards { width: {{ board_size }}px; max-width: 100%; }
    .replay-boards .frame-board { display: none; }
    .replay-boards .frame-board.is-active { display: block; }
    .replay-boards svg { width: 100%; height: auto; display: block; }
    .replay-side { flex: 1; min-width: 240px; max-width: 460px; }
    .replay-detail { display: none; background: #fff; border: 1px solid #e7e5e4; border-radius: .5rem; padding: 1rem; }
    .replay-detail.is-active { display: block; }
    .replay-detail .headline { font-weight: 600; }
    .replay-detail .num { color: #78716c; }
    .replay-detail .side-tag { color: #78716c; font-weight: 400; }
    .replay-controls { display: flex; gap: .5rem; align-items: center; justify-content: center; margin: 1rem 0; flex-wrap: wrap; }
    .replay-controls button {
      font: inherit; cursor: pointer; border: 1px solid #d6d3d1; background: #fff;
      border-radius: .375rem; padding: .3rem .7rem; line-height: 1;
    }
    .replay-controls button:hover { background: #f5f5f4; }
    .replay-slider { flex: 1; min-width: 140px; max-width: 360px; }
    .replay-counter { font-variant-numeric: tabular-nums; color: #57534e; font-size: .85rem; min-width: 4rem; text-align: center; }
    ol.replay-moves {
      list-style: none; padding: 0; margin: 1rem auto 0; max-width: 720px;
      display: flex; flex-wrap: wrap; gap: .3rem;
    }
    ol.replay-moves li {
      cursor: pointer; border: 1px solid #e7e5e4; background: #fff; border-radius: .375rem;
      padding: .25rem .5rem; font-size: .9rem;
    }
    ol.replay-moves li:hover { background: #f5f5f4; }
    ol.replay-moves li.is-current { background: #1c1917; color: #fafaf9; border-color: #1c1917; }
    ol.replay-moves li.is-current .num { color: #d6d3d1; }
    .key-moments li[data-frame] { cursor: pointer; }
    .key-moments li[data-frame]:hover { background: #f5f5f4; }
    footer { text-align: center; color: #a8a29e; font-size: .8rem; margin-top: 2rem; }
    .report-actions { margin: .75rem 0 0; }
    .dl-btn {
      font: inherit; cursor: pointer; border: 1px solid #d6d3d1; background: #fff;
      border-radius: .375rem; padding: .35rem .8rem; color: #1c1917;
    }
    .dl-btn:hover { background: #f5f5f4; }
  </style>
</head>
<body>
<main>
  <header class="report">
    <h1>{{ white.display_name }} vs {{ black.display_name }}</h1>
    <div class="meta">{{ event }} · {{ date }} · партия <code>{{ game.id }}</code></div>
    <div class="players">
      <div class="player">
        <div class="side">Белые</div>
        <div class="name">{{ white.display_name }}</div>
        <div class="model">{{ white.model_id }} · {{ white.provider }}</div>
      </div>
      <div class="player">
        <div class="side">Чёрные</div>
        <div class="name">{{ black.display_name }}</div>
        <div class="model">{{ black.model_id }} · {{ black.provider }}</div>
      </div>
    </div>
    <div class="result">
      {{ result_text }} <span class="score">({{ game.result }})</span>
      {% if game.termination %}<span class="termination">{{ game.termination }}</span>{% endif %}
    </div>
    {% if pgn %}
    <div class="report-actions">
      <button type="button" id="download-pgn" class="dl-btn">⬇ Скачать PGN</button>
    </div>
    <textarea id="pgn-data" hidden>{{ pgn }}</textarea>
    {% endif %}
  </header>

  {% if game.analysis %}
  <section class="analysis">
    <h2>Анализ партии</h2>
    <div class="analysis-sides">
      {% for side, player in [("white", white), ("black", black)] %}
      {% set stats = game.analysis.white if side == "white" else game.analysis.black %}
      <div class="analysis-side">
        <div class="side-name">{% if side == "white" %}Белые{% else %}Чёрные{% endif %} · {{ player.display_name }}</div>
        <div class="accuracy">
          {% if stats.accuracy is not none %}{{ "%.0f"|format(stats.accuracy * 100) }}%{% else %}—{% endif %}
          <span class="label">точность</span>
        </div>
        <div class="counts">{{ stats.blunders }} зевков · {{ stats.mistakes }} ошибок · {{ stats.inaccuracies }} неточностей</div>
      </div>
      {% endfor %}
    </div>
    {% if game.analysis.key_moments %}
    <ul class="key-moments">
      {% for km in game.analysis.key_moments %}
      <li data-frame="{{ km.ply }}">
        <span class="num">{{ (km.ply + 1) // 2 }}{% if km.ply % 2 == 1 %}.{% else %}...{% endif %}</span>
        <span class="badge {{ km.classification }}">{{ km.classification }}</span>
        {% if km.classification|glyph %}<span class="glyph">{{ km.classification|glyph }}</span>{% endif %}
        {% if km.comment %}<span class="comment">{{ km.comment }}</span>{% endif %}
      </li>
      {% endfor %}
    </ul>
    {% endif %}
  </section>
  {% endif %}

  {% if moves %}
  <section class="replay" id="replay" data-total="{{ moves|length }}">
    <div class="replay-stage">
      {% if start_board %}
      <div class="replay-boards">
        <div class="frame-board is-active" data-frame="0">{{ start_board }}</div>
        {% for m in moves %}
        <div class="frame-board" data-frame="{{ loop.index }}">{{ m.board_svg }}</div>
        {% endfor %}
      </div>
      {% endif %}
      <div class="replay-side">
        <div class="replay-detail is-active" data-frame="0">
          <div class="headline">Начальная позиция</div>
        </div>
        {% for m in moves %}
        <div class="replay-detail" data-frame="{{ loop.index }}">
          <div class="headline">
            <span class="num">{{ m.move_number }}{% if m.record.side == "white" %}.{% else %}...{% endif %}</span>
            {{ m.record.san }}
            <span class="side-tag">({{ m.record.side }})</span>
            {% if m.record.classification %}<span class="badge {{ m.record.classification }}">{{ m.record.classification }}</span>{% if m.record.classification|glyph %}<span class="glyph">{{ m.record.classification|glyph }}</span>{% endif %}{% endif %}
            {% if m.record.engine_eval_cp is not none %}<span class="eval">{{ "%+d"|format(m.record.engine_eval_cp) }} cp</span>{% endif %}
          </div>
          {% if m.record.reasoning %}
          <p class="reasoning">{{ m.record.reasoning }}</p>
          {% else %}
          <p class="reasoning empty">(без объяснения)</p>
          {% endif %}
          {% if m.record.strategy %}
          <p class="plan"><span class="plan-status status-{{ m.record.plan_status }}">{{ m.record.plan_status }}</span><span class="label">План:</span> {{ m.record.strategy }}</p>
          {% endif %}
          {% if m.record.hint %}
          <div class="hint">Подсказка движка: {{ m.record.hint.best_move }}{% if m.record.hint.eval_cp is not none %} ({{ "%+d"|format(m.record.hint.eval_cp) }} cp){% endif %}</div>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </div>

    <div class="replay-controls">
      <button type="button" data-nav="first" title="К началу (Home)">⏮</button>
      <button type="button" data-nav="prev" title="Назад (←)">◀</button>
      <input class="replay-slider" type="range" min="0" max="{{ moves|length }}" value="0" aria-label="Перемотка ходов">
      <button type="button" data-nav="next" title="Вперёд (→)">▶</button>
      <button type="button" data-nav="last" title="К концу (End)">⏭</button>
      <span class="replay-counter">0 / {{ moves|length }}</span>
    </div>

    <ol class="replay-moves">
      {% for m in moves %}
      <li data-frame="{{ loop.index }}">
        <span class="num">{{ m.move_number }}{% if m.record.side == "white" %}.{% else %}...{% endif %}</span>
        {{ m.record.san }}
        {% if m.record.classification %}<span class="badge {{ m.record.classification }}">{{ m.record.classification }}</span>{% if m.record.classification|glyph %}<span class="glyph">{{ m.record.classification|glyph }}</span>{% endif %}{% endif %}
      </li>
      {% endfor %}
    </ol>

    <script>
    (function () {
      var root = document.getElementById("replay");
      if (!root) return;
      var total = parseInt(root.dataset.total, 10) || 0;
      var slider = root.querySelector(".replay-slider");
      var counter = root.querySelector(".replay-counter");
      var boards = root.querySelectorAll(".frame-board");
      var details = root.querySelectorAll(".replay-detail");
      var items = root.querySelectorAll(".replay-moves li");
      // Ключевые моменты живут в блоке анализа над плеером — тоже навигируют.
      var keyMoments = document.querySelectorAll(".key-moments li[data-frame]");
      var current = -1;

      function setActive(nodes, frame) {
        for (var i = 0; i < nodes.length; i++) {
          var f = parseInt(nodes[i].dataset.frame, 10);
          nodes[i].classList.toggle("is-active", f === frame);
          nodes[i].classList.toggle("is-current", f === frame);
        }
      }

      function show(frame) {
        frame = Math.max(0, Math.min(total, frame));
        if (frame === current) return;
        current = frame;
        setActive(boards, frame);
        setActive(details, frame);
        setActive(items, frame);
        if (slider) slider.value = frame;
        if (counter) counter.textContent = frame + " / " + total;
      }

      root.querySelectorAll("[data-nav]").forEach(function (btn) {
        btn.addEventListener("click", function () {
          var nav = btn.dataset.nav;
          if (nav === "first") show(0);
          else if (nav === "prev") show(current - 1);
          else if (nav === "next") show(current + 1);
          else if (nav === "last") show(total);
        });
      });
      if (slider) slider.addEventListener("input", function () { show(parseInt(slider.value, 10)); });
      items.forEach(function (el) {
        el.addEventListener("click", function () { show(parseInt(el.dataset.frame, 10)); });
      });
      keyMoments.forEach(function (el) {
        el.addEventListener("click", function () { show(parseInt(el.dataset.frame, 10)); });
      });
      document.addEventListener("keydown", function (e) {
        if (e.key === "ArrowLeft") { show(current - 1); e.preventDefault(); }
        else if (e.key === "ArrowRight") { show(current + 1); e.preventDefault(); }
        else if (e.key === "Home") { show(0); e.preventDefault(); }
        else if (e.key === "End") { show(total); e.preventDefault(); }
      });

      show(0);
    })();
    </script>
  </section>
  {% else %}
  <p>В партии нет ходов.</p>
  {% endif %}

  <footer>Сгенерировано LLM Chess Arena из game.json</footer>
</main>
{% if pgn %}
<script>
(function () {
  var btn = document.getElementById("download-pgn");
  var data = document.getElementById("pgn-data");
  if (!btn || !data) return;
  btn.addEventListener("click", function () {
    var blob = new Blob([data.value], { type: "application/x-chess-pgn" });
    var url = URL.createObjectURL(blob);
    var a = document.createElement("a");
    a.href = url;
    a.download = {{ pgn_filename|tojson }};
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  });
})();
</script>
{% endif %}
</body>
</html>
