<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <style>
    :root { color-scheme: light dark; }
    * { box-sizing: border-box; }
    body {
      font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      margin: 0; padding: 2rem; line-height: 1.5;
      background: #f5f5f4; color: #1c1917;
    }
    main { max-width: 980px; margin: 0 auto; }
    header.stats { text-align: center; margin-bottom: 1.5rem; }
    header.stats h1 { margin: 0 0 .25rem; font-size: 1.5rem; }
    header.stats .meta { color: #57534e; font-size: .9rem; }
    table.standings {
      width: 100%; border-collapse: collapse; background: #fff;
      border: 1px solid #e7e5e4; border-radius: .5rem; overflow: hidden;
      font-variant-numeric: tabular-nums;
    }
    table.standings th, table.standings td { padding: .5rem .65rem; text-align: right; }
    table.standings th { background: #f5f5f4; font-size: .75rem; text-transform: uppercase; letter-spacing: .03em; color: #78716c; }
    table.standings td.model, table.standings th.model { text-align: left; }
    table.standings td.rank, table.standings th.rank { text-align: center; color: #78716c; }
    table.standings tbody tr { border-top: 1px solid #f0efed; }
    table.standings tbody tr:nth-child(even) { background: #fafaf9; }
    .model .name { font-weight: 600; }
    .points { font-weight: 700; }
    .muted { color: #a8a29e; }
    .empty { text-align: center; color: #78716c; padding: 2rem; }
    footer { text-align: center; color: #a8a29e; font-size: .8rem; margin-top: 1.5rem; }
  </style>
</head>
<body>
<main>
  <header class="stats">
    <h1>{{ title }}</h1>
    <div class="meta">Учтённых партий: {{ table.total_games }}</div>
  </header>

  {% if table.models %}
  <table class="standings">
    <thead>
      <tr>
        <th class="rank">#</th>
        <th class="model">Модель</th>
        <th>Партии</th>
        <th>В</th>
        <th>Н</th>
        <th>П</th>
        <th>Очки</th>
        <th>Score %</th>
        <th>Точность</th>
        <th>Зевки</th>
        <th>Ошибки</th>
        <th>Неточн.</th>
        <th>Подск.</th>
      </tr>
    </thead>
    <tbody>
      {% for row in table.models %}
      <tr>
        <td class="rank">{{ loop.index }}</td>
        <td class="model">
          <span class="name">{{ row.display_name }}</span>
          <span class="muted">({{ row.model_id }})</span>
        </td>
        <td>{{ row.games }}</td>
        <td>{{ row.wins }}</td>
        <td>{{ row.draws }}</td>
        <td>{{ row.losses }}</td>
        <td class="points">{{ "%.1f"|format(row.points) }}</td>
        <td>{{ "%.1f"|format(row.score_pct) }}</td>
        <td>
          {% if row.avg_accuracy is not none %}
          {{ "%.1f"|format(row.avg_accuracy * 100) }}%
          {% else %}
          <span class="muted">—</span>
          {% endif %}
        </td>
        <td>{{ row.blunders }}</td>
        <td>{{ row.mistakes }}</td>
        <td>{{ row.inaccuracies }}</td>
        <td>{{ row.hints_used }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p class="empty">Нет данных для статистики.</p>
  {% endif %}

  <footer>LLM Chess Arena · агрегированная статистика</footer>
</main>
</body>
</html>
