# LLM Chess Arena — пример секретов.
# Скопируй в .env и подставь реальные значения. .env закоммичен НЕ будет (см. .gitignore).
# Имена переменных должны совпадать с api_key_env в config.yaml (секция providers).

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# (опц.) Доступ к веб-UI «по ссылке»: если задан секрет, на сайт пускают только по
# ссылке с этим токеном (https://адрес/?token=ЗНАЧЕНИЕ → токен сохранится в cookie).
# Пусто/не задан — сайт открыт всем. Сгенерировать токен:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
ARENA_ACCESS_TOKEN=
